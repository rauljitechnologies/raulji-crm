# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:yourpassword@localhost:5432/raulji_crm"

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_random_64_char_string
JWT_REFRESH_SECRET=change_this_to_a_different_random_64_char_string
JWT_EXPIRES_IN=1h
REFRESH_TOKEN_EXPIRES_IN=30d

# ── Frontend / CORS ───────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# ── WhatsApp / WATI Integration ───────────────────────────────────────────────
# Leave blank to run in simulation mode
WATI_API_ENDPOINT=
WATI_API_TOKEN=
WATI_WEBHOOK_SECRET=

# ── Google Drive Backup (via rclone) ──────────────────────────────────────────
# 1. brew install rclone
# 2. rclone config → New remote → name: gdrive → type: drive → authorize via browser
# 3. Set RCLONE_DRIVE_ROOT to the folder name inside your Drive
RCLONE_REMOTE=gdrive
RCLONE_DRIVE_ROOT=RauljiCRM-Backups
GOOGLE_DRIVE_BACKUP_FOLDER_ID=your_google_drive_folder_id_here

# ── Email (Nodemailer) ────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=your@gmail.com

# ── Razorpay (optional) ───────────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ── File Upload ───────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=10
