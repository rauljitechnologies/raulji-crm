generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  companyId    String    @id @default(cuid()) @map("company_id")
  name         String
  slug         String    @unique
  domain       String?
  logo         String?
  gst          String?
  industry     String?
  phone        String?
  email        String?
  website      String?
  plan         Plan      @default(STARTER)
  status       String    @default("ACTIVE")
  apiKey       String    @unique @map("api_key")
  apiSecret    String    @map("api_secret")
  address      Json      @default("{}")
  bankDetails  Json?     @map("bank_details")
  settings     Json      @default("{}")
  deletedAt    DateTime? @map("deleted_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  users            User[]
  leads            Lead[]
  deals            Deal[]
  quotations       Quotation[]
  invoices         Invoice[]
  webhooks         Webhook[]
  clients          Client[]
  messageTemplates MessageTemplate[]
  automationRules  AutomationRule[]
  campaigns        Campaign[]
  autoReplyRules   AutoReplyRule[]
  projects           Project[]
  projectAssignments ProjectAssignment[]
  seoAudits   SeoAudit[]
  seoKeywords SeoKeyword[]

  @@map("companies")
}

enum Plan {
  STARTER
  GROWTH
  ENTERPRISE
}

model User {
  userId       String    @id @default(cuid()) @map("user_id")
  name         String
  email        String    @unique
  phone        String?
  password     String
  role         Role      @default(SALES_REP)
  permissions  Json      @default("{}")
  avatar       String?
  companyId    String?   @map("company_id")
  isActive     Boolean   @default(true)  @map("is_active")
  isVerified   Boolean   @default(false) @map("is_verified")
  inviteToken  String?   @map("invite_token")
  inviteExpiry DateTime? @map("invite_expiry")
  lastLogin    DateTime? @map("last_login")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  company       Company?      @relation(fields: [companyId], references: [companyId])
  assignedLeads Lead[]        @relation("AssignedLeads")
  activities    Activity[]
  refreshTokens RefreshToken[]

  @@map("users")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  SALES_MANAGER
  SALES_REP
  VIEWER
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Lead {
  leadId         String    @id @default(cuid()) @map("lead_id")
  companyId      String    @map("company_id")
  name           String
  email          String?
  phone          String
  city           String?
  state          String?
  source         String    @default("MANUAL")
  status         String    @default("NEW")
  priority       String    @default("MEDIUM")
  dealValue      Float?    @map("deal_value")
  currency       String    @default("INR")
  aiScore        Int?      @map("ai_score")
  aiScoreFactors Json?     @map("ai_score_factors")
  assignedToId   String?   @map("assigned_to_id")
  tags           String[]  @default([])
  notes          String?
  customFields   Json?     @map("custom_fields")
  lastActivityAt DateTime? @map("last_activity_at")
  nextFollowUpAt DateTime? @map("next_follow_up_at")
  isDeleted      Boolean   @default(false) @map("is_deleted")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  country        String?
  service        String?

  company    Company    @relation(fields: [companyId], references: [companyId])
  assignedTo User?      @relation("AssignedLeads", fields: [assignedToId], references: [userId])
  activities Activity[]
  deals      Deal[]
  quotations Quotation[]
  invoices   Invoice[]
  communications Communication[]
  campaignLeads  CampaignLead[]

  @@unique([companyId, email])
  @@index([companyId, status])
  @@index([companyId, source])
  @@map("leads")
}

model Activity {
  activityId  String   @id @default(cuid()) @map("activity_id")
  companyId   String   @map("company_id")
  leadId      String?  @map("lead_id")
  userId      String?  @map("user_id")
  type        String
  description String
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")

  lead Lead? @relation(fields: [leadId], references: [leadId])
  user User? @relation(fields: [userId], references: [userId])

  @@map("activities")
}

model Deal {
  dealId            String    @id @default(cuid()) @map("deal_id")
  companyId         String    @map("company_id")
  leadId            String?   @map("lead_id")
  name              String
  value             Float     @default(0)
  currency          String    @default("INR")
  stage             String    @default("NEW_LEAD")
  probability       Int       @default(0)
  expectedCloseDate DateTime? @map("expected_close_date")
  closedAt          DateTime? @map("closed_at")
  lostReason        String?   @map("lost_reason")
  assignedToId      String?   @map("assigned_to_id")
  tags              String[]  @default([])
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  company    Company    @relation(fields: [companyId], references: [companyId])
  lead       Lead?      @relation(fields: [leadId], references: [leadId])
  quotations Quotation[]

  @@map("deals")
}

model Quotation {
  quotationId          String    @id @default(cuid()) @map("quotation_id")
  quotationNumber      String    @map("quotation_number")
  companyId            String    @map("company_id")
  leadId               String?   @map("lead_id")
  dealId               String?   @map("deal_id")
  clientName           String    @map("client_name")
  clientEmail          String?   @map("client_email")
  clientPhone          String?   @map("client_phone")
  clientAddress        String?   @map("client_address")
  clientGst            String?   @map("client_gst")
  validUntil           DateTime? @map("valid_until")
  currency             String    @default("INR")
  items                Json
  subtotal             Float     @default(0)
  totalGst             Float     @default(0) @map("total_gst")
  totalDiscount        Float     @default(0) @map("total_discount")
  grandTotal           Float     @default(0) @map("grand_total")
  status               String    @default("DRAFT")
  notes                String?
  termsConditions      String?   @map("terms_conditions")
  pdfUrl               String?   @map("pdf_url")
  sentAt               DateTime? @map("sent_at")
  convertedToInvoiceId String?   @map("converted_to_invoice_id")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  company Company  @relation(fields: [companyId], references: [companyId])
  lead    Lead?    @relation(fields: [leadId], references: [leadId])
  deal    Deal?    @relation(fields: [dealId], references: [dealId])

  @@map("quotations")
}

model Invoice {
  invoiceId      String    @id @default(cuid()) @map("invoice_id")
  invoiceNumber  String    @map("invoice_number")
  companyId      String    @map("company_id")
  leadId         String?   @map("lead_id")
  quotationId    String?   @map("quotation_id")
  clientName     String    @map("client_name")
  clientEmail    String?   @map("client_email")
  clientPhone    String?   @map("client_phone")
  clientAddress  String?   @map("client_address")
  clientGst      String?   @map("client_gst")
  invoiceDate    DateTime  @default(now()) @map("invoice_date")
  dueDate        DateTime  @map("due_date")
  currency       String    @default("INR")
  items          Json
  subtotal       Float     @default(0)
  totalGst       Float     @default(0) @map("total_gst")
  totalDiscount  Float     @default(0) @map("total_discount")
  grandTotal     Float     @default(0) @map("grand_total")
  paidAmount     Float?    @map("paid_amount")
  status         String    @default("DRAFT")
  paymentTerms   String?   @map("payment_terms")
  bankDetails    Json?     @map("bank_details")
  paymentLink    String?   @map("payment_link")
  pdfUrl         String?   @map("pdf_url")
  paidAt         DateTime? @map("paid_at")
  paymentMethod  String?   @map("payment_method")
  transactionId  String?   @map("transaction_id")
  notes          String?
  sentAt         DateTime? @map("sent_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [companyId])
  lead    Lead?   @relation(fields: [leadId], references: [leadId])

  @@map("invoices")
}

model Client {
  clientId   String    @id @default(cuid()) @map("client_id")
  companyId  String    @map("company_id")
  name       String
  email      String?
  phone      String?
  address    String?
  city       String?
  state      String?
  pincode    String?
  gst        String?
  pan        String?
  notes      String?
  isActive   Boolean   @default(true) @map("is_active")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [companyId])

  @@index([companyId])
  @@map("clients")
}

model Webhook {
  webhookId String   @id @default(cuid()) @map("webhook_id")
  companyId String   @map("company_id")
  url       String
  events    String[]
  secret    String
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [companyId])

  @@map("webhooks")
}

// ─── WhatsApp / Messaging ──────────────────────────────────────────────────

model MessageTemplate {
  templateId String   @id @default(cuid()) @map("template_id")
  companyId  String   @map("company_id")
  name       String
  category   String   @default("CUSTOM")    // WELCOME, FOLLOWUP, PROPOSAL, CLOSING, CUSTOM
  channel    String   @default("WHATSAPP")  // WHATSAPP | EMAIL | SMS
  subject    String?                         // email subject
  body       String
  variables  String[] @default([])
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  company         Company          @relation(fields: [companyId], references: [companyId])
  automationRules AutomationRule[]
  communications  Communication[]

  @@index([companyId])
  @@map("message_templates")
}

model AutomationRule {
  ruleId         String   @id @default(cuid()) @map("rule_id")
  companyId      String   @map("company_id")
  name           String
  isActive       Boolean  @default(true)  @map("is_active")
  trigger        String                   // LEAD_CREATED | STATUS_CHANGED | FOLLOW_UP_DUE | VALIDATION_FAILED
  triggerValue   String?  @map("trigger_value")
  channel        String   @default("WHATSAPP")
  templateId     String   @map("template_id")
  delayMinutes   Int      @default(0)     @map("delay_minutes")
  conditions     Json?
  executionCount Int      @default(0)     @map("execution_count")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt      @map("updated_at")

  company  Company         @relation(fields: [companyId], references: [companyId])
  template MessageTemplate @relation(fields: [templateId], references: [templateId])
  jobs     AutomationJob[]

  @@index([companyId, trigger])
  @@map("automation_rules")
}

model AutomationJob {
  jobId       String    @id @default(cuid()) @map("job_id")
  ruleId      String    @map("rule_id")
  leadId      String    @map("lead_id")
  companyId   String    @map("company_id")
  status      String    @default("PENDING") // PENDING | SENT | FAILED | CANCELLED
  scheduledAt DateTime  @map("scheduled_at")
  executedAt  DateTime? @map("executed_at")
  error       String?
  createdAt   DateTime  @default(now()) @map("created_at")

  rule AutomationRule @relation(fields: [ruleId], references: [ruleId])

  @@index([status, scheduledAt])
  @@index([companyId, leadId])
  @@map("automation_jobs")
}

model Communication {
  commId        String    @id @default(cuid()) @map("comm_id")
  companyId     String    @map("company_id")
  leadId        String?   @map("lead_id")
  channel       String                          // WHATSAPP | EMAIL | CALL | NOTE | SMS
  direction     String    @default("OUTBOUND")  // OUTBOUND | INBOUND
  status        String    @default("SENT")      // SENT | DELIVERED | READ | FAILED | PENDING
  fromNumber    String?   @map("from_number")
  toNumber      String?   @map("to_number")
  templateId    String?   @map("template_id")
  subject       String?
  body          String
  watiMessageId String?   @map("wati_message_id")
  metadata      Json?
  sentAt        DateTime? @map("sent_at")
  deliveredAt   DateTime? @map("delivered_at")
  readAt        DateTime? @map("read_at")
  userId        String?   @map("user_id")
  createdAt     DateTime  @default(now()) @map("created_at")

  lead     Lead?            @relation(fields: [leadId], references: [leadId])
  template MessageTemplate? @relation(fields: [templateId], references: [templateId])

  @@index([leadId, createdAt])
  @@index([companyId, channel])
  @@map("communications")
}

model AutoReplyRule {
  replyRuleId String   @id @default(cuid()) @map("reply_rule_id")
  companyId   String   @map("company_id")
  keyword     String
  matchType   String   @default("CONTAINS") // CONTAINS | EXACT | STARTS_WITH
  replyBody   String   @map("reply_body")
  isActive    Boolean  @default(true)  @map("is_active")
  priority    Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt      @map("updated_at")

  company Company @relation(fields: [companyId], references: [companyId])

  @@index([companyId, isActive])
  @@map("auto_reply_rules")
}

// ─── Campaigns ─────────────────────────────────────────────────────────────

model Campaign {
  campaignId     String    @id @default(cuid()) @map("campaign_id")
  companyId      String    @map("company_id")
  name           String
  description    String?
  channel        String    @default("WHATSAPP") // WHATSAPP | EMAIL | BOTH
  status         String    @default("DRAFT")    // DRAFT | RUNNING | COMPLETED | CANCELLED
  templateId     String?   @map("template_id")
  subject        String?
  body           String?
  filters        Json?
  scheduledAt    DateTime? @map("scheduled_at")
  startedAt      DateTime? @map("started_at")
  completedAt    DateTime? @map("completed_at")
  totalLeads     Int       @default(0) @map("total_leads")
  sentCount      Int       @default(0) @map("sent_count")
  deliveredCount Int       @default(0) @map("delivered_count")
  failedCount    Int       @default(0) @map("failed_count")
  createdById    String?   @map("created_by_id")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt      @map("updated_at")

  company       Company        @relation(fields: [companyId], references: [companyId])
  campaignLeads CampaignLead[]

  @@index([companyId, status])
  @@map("campaigns")
}

model CampaignLead {
  id          String    @id @default(cuid())
  campaignId  String    @map("campaign_id")
  leadId      String    @map("lead_id")
  status      String    @default("PENDING") // PENDING | SENT | DELIVERED | FAILED
  sentAt      DateTime? @map("sent_at")
  deliveredAt DateTime? @map("delivered_at")
  error       String?
  createdAt   DateTime  @default(now()) @map("created_at")

  campaign Campaign @relation(fields: [campaignId], references: [campaignId])
  lead     Lead     @relation(fields: [leadId], references: [leadId])

  @@unique([campaignId, leadId])
  @@index([campaignId, status])
  @@map("campaign_leads")
}

// ─── Backup Logs ────────────────────────────────────────────────────────────

model BackupLog {
  id            String    @id @default(cuid())
  stamp         String                          // "2026-03-28_05-00-00"
  label         String                          // "28 Mar 2026, 05:00 AM IST"
  status        String    @default("RUNNING")   // RUNNING | SUCCESS | FAILED | PARTIAL
  trigger       String    @default("SCHEDULED") // SCHEDULED | MANUAL
  dbFile        String?   @map("db_file")       // local path for download
  codeFile      String?   @map("code_file")     // local path for download
  dbSizeBytes   Int?      @map("db_size_bytes")
  codeSizeBytes Int?      @map("code_size_bytes")
  driveFolder   String?   @map("drive_folder")  // rclone destination path
  error         String?
  completedAt   DateTime? @map("completed_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  @@index([status])
  @@index([createdAt])
  @@map("backup_logs")
}

// ─── Projects ───────────────────────────────────────────────────────────────

model Project {
  projectId    String    @id @default(cuid()) @map("project_id")
  companyId    String    @map("company_id")      // owner company
  name         String
  description  String?
  clientName   String?   @map("client_name")
  status       String    @default("ACTIVE")       // ACTIVE | ON_HOLD | COMPLETED | CANCELLED
  priority     String    @default("MEDIUM")        // LOW | MEDIUM | HIGH | CRITICAL
  startDate    DateTime? @map("start_date")
  endDate      DateTime? @map("end_date")
  budget       Float?
  currency     String    @default("INR")
  tags         String[]  @default([])
  notes        String?
  createdBy    String?   @map("created_by")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt      @map("updated_at")

  company     Company             @relation(fields: [companyId], references: [companyId])
  assignments ProjectAssignment[]
  documents   ProjectDocument[]
  credentials ProjectCredential[]
  history     ProjectHistory[]

  @@index([companyId, status])
  @@map("projects")
}

model ProjectAssignment {
  id          String   @id @default(cuid())
  projectId   String   @map("project_id")
  companyId   String   @map("company_id")   // assigned company (not owner)
  role        String   @default("MEMBER")   // OWNER | MEMBER | VIEWER
  assignedAt  DateTime @default(now()) @map("assigned_at")

  project Project @relation(fields: [projectId], references: [projectId], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [companyId])

  @@unique([projectId, companyId])
  @@map("project_assignments")
}

model ProjectDocument {
  docId      String   @id @default(cuid()) @map("doc_id")
  projectId  String   @map("project_id")
  name       String
  fileUrl    String?  @map("file_url")
  fileSize   Int?     @map("file_size")
  mimeType   String?  @map("mime_type")
  notes      String?
  uploadedBy String?  @map("uploaded_by")
  createdAt  DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [projectId], onDelete: Cascade)

  @@index([projectId])
  @@map("project_documents")
}

model ProjectCredential {
  credId     String   @id @default(cuid()) @map("cred_id")
  projectId  String   @map("project_id")
  label      String
  username   String?
  password   String?
  url        String?
  notes      String?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt      @map("updated_at")

  project Project @relation(fields: [projectId], references: [projectId], onDelete: Cascade)

  @@index([projectId])
  @@map("project_credentials")
}

model ProjectHistory {
  histId      String   @id @default(cuid()) @map("hist_id")
  projectId   String   @map("project_id")
  action      String
  description String
  userId      String?  @map("user_id")
  userName    String?  @map("user_name")
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [projectId], onDelete: Cascade)

  @@index([projectId, createdAt])
  @@map("project_history")
}

// ─── SEO Audits ─────────────────────────────────────────────────────────────

model SeoAudit {
  auditId     String   @id @default(cuid()) @map("audit_id")
  companyId   String   @map("company_id")
  domain      String
  score       Int      @default(0)
  status      String   @default("PENDING")  // PENDING | RUNNING | DONE | FAILED
  summary     Json     @default("{}")
  issues      Json     @default("[]")
  pageData    Json     @default("{}")
  triggeredBy String   @default("SCHEDULED") @map("triggered_by")
  createdAt   DateTime @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [companyId], onDelete: Cascade)

  @@index([companyId, createdAt])
  @@map("seo_audits")
}

model SeoKeyword {
  keywordId     String   @id @default(cuid()) @map("keyword_id")
  companyId     String   @map("company_id")
  keyword       String
  targetUrl     String?  @map("target_url")
  targetCountry String   @default("IN") @map("target_country")
  notes         String?
  createdAt     DateTime @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [companyId], onDelete: Cascade)

  @@index([companyId])
  @@map("seo_keywords")
}
