generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  companyId    String    @id @default(cuid()) @map("company_id")
  name         String
  slug         String    @unique
  domain       String?
  logo         String?
  gst          String?
  industry     String?
  phone        String?
  email        String?
  website      String?
  plan         Plan      @default(STARTER)
  status       String    @default("ACTIVE")
  apiKey       String    @unique @map("api_key")
  apiSecret    String    @map("api_secret")
  address      Json      @default("{}")
  bankDetails  Json?     @map("bank_details")
  settings     Json      @default("{}")
  deletedAt    DateTime? @map("deleted_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  users      User[]
  leads      Lead[]
  deals      Deal[]
  quotations Quotation[]
  invoices   Invoice[]
  webhooks   Webhook[]
  clients    Client[]

  @@map("companies")
}

enum Plan {
  STARTER
  GROWTH
  ENTERPRISE
}

model User {
  userId       String    @id @default(cuid()) @map("user_id")
  name         String
  email        String    @unique
  phone        String?
  password     String
  role         Role      @default(SALES_REP)
  permissions  Json      @default("{}")
  avatar       String?
  companyId    String?   @map("company_id")
  isActive     Boolean   @default(true) @map("is_active")
  isVerified   Boolean   @default(false) @map("is_verified")
  inviteToken  String?   @map("invite_token")
  inviteExpiry DateTime? @map("invite_expiry")
  lastLogin    DateTime? @map("last_login")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  company       Company?      @relation(fields: [companyId], references: [companyId])
  assignedLeads Lead[]        @relation("AssignedLeads")
  activities    Activity[]
  refreshTokens RefreshToken[]

  @@map("users")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  SALES_MANAGER
  SALES_REP
  VIEWER
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Lead {
  leadId         String    @id @default(cuid()) @map("lead_id")
  companyId      String    @map("company_id")
  name           String
  email          String?
  phone          String
  city           String?
  state          String?
  source         String    @default("MANUAL")
  status         String    @default("NEW")
  priority       String    @default("MEDIUM")
  dealValue      Float?    @map("deal_value")
  currency       String    @default("INR")
  aiScore        Int?      @map("ai_score")
  assignedToId   String?   @map("assigned_to_id")
  tags           String[]  @default([])
  notes          String?
  customFields   Json?     @map("custom_fields")
  lastActivityAt DateTime? @map("last_activity_at")
  nextFollowUpAt DateTime? @map("next_follow_up_at")
  isDeleted      Boolean   @default(false) @map("is_deleted")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  company    Company    @relation(fields: [companyId], references: [companyId])
  assignedTo User?      @relation("AssignedLeads", fields: [assignedToId], references: [userId])
  activities Activity[]
  deals      Deal[]
  quotations Quotation[]
  invoices   Invoice[]

  @@unique([companyId, email])
  @@index([companyId, status])
  @@map("leads")
}

model Activity {
  activityId  String   @id @default(cuid()) @map("activity_id")
  companyId   String   @map("company_id")
  leadId      String?  @map("lead_id")
  userId      String?  @map("user_id")
  type        String
  description String
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")

  lead Lead? @relation(fields: [leadId], references: [leadId])
  user User? @relation(fields: [userId], references: [userId])

  @@map("activities")
}

model Deal {
  dealId            String    @id @default(cuid()) @map("deal_id")
  companyId         String    @map("company_id")
  leadId            String?   @map("lead_id")
  name              String
  value             Float     @default(0)
  currency          String    @default("INR")
  stage             String    @default("NEW_LEAD")
  probability       Int       @default(0)
  expectedCloseDate DateTime? @map("expected_close_date")
  closedAt          DateTime? @map("closed_at")
  lostReason        String?   @map("lost_reason")
  assignedToId      String?   @map("assigned_to_id")
  tags              String[]  @default([])
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  company    Company    @relation(fields: [companyId], references: [companyId])
  lead       Lead?      @relation(fields: [leadId], references: [leadId])
  quotations Quotation[]

  @@map("deals")
}

model Quotation {
  quotationId          String    @id @default(cuid()) @map("quotation_id")
  quotationNumber      String    @map("quotation_number")
  companyId            String    @map("company_id")
  leadId               String?   @map("lead_id")
  dealId               String?   @map("deal_id")
  clientId             String?   @map("client_id")
  clientName           String    @map("client_name")
  clientEmail          String?   @map("client_email")
  clientPhone          String?   @map("client_phone")
  clientAddress        String?   @map("client_address")
  clientGst            String?   @map("client_gst")
  validUntil           DateTime? @map("valid_until")
  currency             String    @default("INR")
  items                Json
  subtotal             Float     @default(0)
  totalGst             Float     @default(0) @map("total_gst")
  totalDiscount        Float     @default(0) @map("total_discount")
  grandTotal           Float     @default(0) @map("grand_total")
  status               String    @default("DRAFT")
  notes                String?
  termsConditions      String?   @map("terms_conditions")
  pdfUrl               String?   @map("pdf_url")
  sentAt               DateTime? @map("sent_at")
  convertedToInvoiceId String?   @map("converted_to_invoice_id")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  company Company  @relation(fields: [companyId], references: [companyId])
  lead    Lead?    @relation(fields: [leadId], references: [leadId])
  deal    Deal?    @relation(fields: [dealId], references: [dealId])

  @@map("quotations")
}

model Invoice {
  invoiceId      String    @id @default(cuid()) @map("invoice_id")
  invoiceNumber  String    @map("invoice_number")
  invoiceDate    DateTime? @default(now()) @map("invoice_date")
  companyId      String    @map("company_id")
  leadId         String?   @map("lead_id")
  quotationId    String?   @map("quotation_id")
  clientId       String?   @map("client_id")
  clientName     String    @map("client_name")
  clientEmail    String?   @map("client_email")
  clientPhone    String?   @map("client_phone")
  clientAddress  String?   @map("client_address")
  clientGst      String?   @map("client_gst")
  dueDate        DateTime  @map("due_date")
  currency       String    @default("INR")
  items          Json
  subtotal       Float     @default(0)
  totalGst       Float     @default(0) @map("total_gst")
  totalDiscount  Float     @default(0) @map("total_discount")
  grandTotal     Float     @default(0) @map("grand_total")
  paidAmount     Float?    @map("paid_amount")
  status         String    @default("DRAFT")
  paymentTerms   String?   @map("payment_terms")
  bankDetails    Json?     @map("bank_details")
  paymentLink    String?   @map("payment_link")
  pdfUrl         String?   @map("pdf_url")
  paidAt         DateTime? @map("paid_at")
  paymentMethod  String?   @map("payment_method")
  transactionId  String?   @map("transaction_id")
  tdsAmount      Float?    @map("tds_amount")
  tdsRate        Float?    @map("tds_rate")
  notes          String?
  sentAt         DateTime? @map("sent_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [companyId])
  lead    Lead?   @relation(fields: [leadId], references: [leadId])

  @@map("invoices")
}

model Webhook {
  webhookId String   @id @default(cuid()) @map("webhook_id")
  companyId String   @map("company_id")
  url       String
  events    String[]
  secret    String
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [companyId])

  @@map("webhooks")
}


model Client {
  clientId  String   @id @default(cuid()) @map("client_id")
  companyId String   @map("company_id")
  name      String
  email     String?
  phone     String?
  address   String?
  city      String?
  state     String?
  pincode   String?
  gst       String?
  pan       String?
  notes     String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [companyId])

  @@index([companyId])
  @@map("clients")
}
